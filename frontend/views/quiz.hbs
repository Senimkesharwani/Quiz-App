<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{quizTitle}} — BrainByte</title>
    <meta name="description" content="Take the {{quizTitle}} quiz. Test your knowledge with {{totalQ}} questions.">
    <link rel="stylesheet" href="/css/quiz.css">
    <link rel="stylesheet" href="/css/globals.css">
</head>
<body>

<!-- Animated Background -->
<div class="quiz-bg">
    <div class="orb"></div>
    <div class="orb"></div>
    <div class="orb"></div>
</div>

<!-- ===== STICKY HEADER ===== -->
<header class="quiz-header">
    <div class="quiz-header-inner">
        <div class="quiz-header-left">
            <a href="/dashboard" class="header-back">← Dashboard</a>
            <div class="quiz-title-bar">
                <h1>{{quizTitle}}</h1>
                <div class="quiz-meta-info">
                    <span>{{totalQ}} Questions</span>
                    <span>•</span>
                    <span>5 min</span>
                </div>
            </div>
        </div>

        <div class="quiz-header-center">
            <div class="timer-box" id="timerBox">
                <span class="timer-icon">⏱️</span>
                <span class="timer-value" id="timerValue">05:00</span>
            </div>
            <div class="progress-pill">
                <span class="progress-text" id="progressText">0 / {{totalQ}}</span>
                <div class="progress-bar-mini">
                    <div class="progress-fill" id="progressFill" style="width: 0%"></div>
                </div>
            </div>
        </div>

        <div class="quiz-header-right">
            <button class="btn-submit-header" id="btnSubmitHeader" onclick="showConfirmModal()">Submit Quiz</button>
        </div>
    </div>
</header>

<!-- Mobile Progress -->
<div class="mobile-progress">
    <div class="timer-box" id="timerBoxMobile">
        <span class="timer-icon">⏱️</span>
        <span class="timer-value" id="timerValueMobile">05:00</span>
    </div>
    <div class="progress-pill" style="flex:1">
        <span class="progress-text" id="progressTextMobile">0 / {{totalQ}}</span>
        <div class="progress-bar-mini" style="flex:1">
            <div class="progress-fill" id="progressFillMobile" style="width: 0%"></div>
        </div>
    </div>
</div>

<!-- ===== MAIN LAYOUT ===== -->
<div class="quiz-layout" id="quizLayout">

    <!-- Left Sidebar -->
    <aside class="quiz-sidebar" id="quizSidebar">
        <div class="sidebar-section">
            <div class="sidebar-title">Question Navigator</div>
            <div class="question-grid" id="questionGrid">
                <!-- Generated by JS -->
            </div>
            <div class="nav-legend">
                <div class="legend-item"><div class="legend-dot current"></div> Current</div>
                <div class="legend-item"><div class="legend-dot answered-dot"></div> Answered</div>
                <div class="legend-item"><div class="legend-dot unanswered"></div> Not Answered</div>
            </div>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-title">Quiz Stats</div>
            <div class="sidebar-stats">
                <div class="sidebar-stat">
                    <span class="stat-label">Answered</span>
                    <span class="stat-val green" id="statAnswered">0</span>
                </div>
                <div class="sidebar-stat">
                    <span class="stat-label">Remaining</span>
                    <span class="stat-val orange" id="statRemaining">{{totalQ}}</span>
                </div>
                <div class="sidebar-stat">
                    <span class="stat-label">Total</span>
                    <span class="stat-val" style="color: var(--accent-cyan)">{{totalQ}}</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="quiz-main-area" id="quizMainArea">
        <!-- Questions rendered by JS -->
    </main>
</div>

<!-- Sidebar Toggle (Mobile) -->
<button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()">☰</button>

<!-- ===== CONFIRM SUBMIT MODAL ===== -->
<div class="modal-overlay" id="confirmModal">
    <div class="modal-box">
        <div class="modal-icon">📋</div>
        <div class="modal-title">Submit Quiz?</div>
        <div class="modal-desc">Are you sure you want to submit? You won't be able to change your answers.</div>
        <div class="modal-stats">
            <div class="modal-stat-item">
                <div class="label">Answered</div>
                <div class="value green" id="modalAnswered">0</div>
            </div>
            <div class="modal-stat-item">
                <div class="label">Unanswered</div>
                <div class="value orange" id="modalUnanswered">0</div>
            </div>
        </div>
        <div class="modal-actions">
            <button class="modal-btn cancel" onclick="hideConfirmModal()">Cancel</button>
            <button class="modal-btn confirm" onclick="submitQuiz()">Yes, Submit</button>
        </div>
    </div>
</div>

<!-- ===== RESULT SCREEN ===== -->
<div class="result-screen" id="resultScreen">
    <div class="result-card">
        <div class="result-emoji" id="resultEmoji">🏆</div>
        <div class="result-title">Quiz Complete!</div>
        <div class="result-subtitle" id="resultSubtitle">Great job on completing the quiz</div>

        <div class="result-score-ring">
            <svg viewBox="0 0 160 160">
                <circle class="ring-bg" cx="80" cy="80" r="70"></circle>
                <circle class="ring-fill" id="ringFill" cx="80" cy="80" r="70"
                    stroke-dasharray="439.82" stroke-dashoffset="439.82"></circle>
            </svg>
            <div class="result-score-text" id="resultScoreText">0/0</div>
            <span class="result-percentage" id="resultPercentage">0%</span>
        </div>

        <div class="result-grid">
            <div class="result-stat">
                <div class="rs-label">Correct</div>
                <div class="rs-value green" id="resultCorrect">0</div>
            </div>
            <div class="result-stat">
                <div class="rs-label">Incorrect</div>
                <div class="rs-value red" id="resultIncorrect">0</div>
            </div>
            <div class="result-stat">
                <div class="rs-label">Unattempted</div>
                <div class="rs-value orange" id="resultSkipped">0</div>
            </div>
            <div class="result-stat">
                <div class="rs-label">Time Taken</div>
                <div class="rs-value blue" id="resultTime">0:00</div>
            </div>
        </div>

        <div class="result-actions">
            <a href="/dashboard" class="result-btn primary">📊 Dashboard</a>
            <button class="result-btn secondary" onclick="reviewAnswers()">📝 Review Answers</button>
        </div>
    </div>
</div>


<script>
// ===== QUIZ DATA (injected from server) =====
var QUIZ = {
    subject: '{{{quizSubject}}}',
    title: '{{{quizTitle}}}',
    questions: {{{questionsJSON}}},
    totalTime: 300 // 5 minutes
};

var totalQ = QUIZ.questions.length;
var currentQ = 0;
var userAnswers = new Array(totalQ).fill(null);
var quizSubmitted = false;
var timerInterval = null;
var timeLeft = QUIZ.totalTime;
var startTime = Date.now();

// ===== INIT =====
function init() {
    buildQuestionGrid();
    renderAllQuestions();
    showQuestion(0);
    startTimer();
}

// ===== QUESTION GRID (Sidebar) =====
function buildQuestionGrid() {
    var grid = document.getElementById('questionGrid');
    var html = '';
    for (var i = 0; i < totalQ; i++) {
        html += '<div class="q-num' + (i === 0 ? ' active' : '') + '" onclick="jumpToQuestion(' + i + ')" id="qNum' + i + '">' + (i + 1) + '</div>';
    }
    grid.innerHTML = html;
}

// ===== RENDER ALL QUESTIONS =====
function renderAllQuestions() {
    var main = document.getElementById('quizMainArea');
    var html = '';
    var letters = ['A', 'B', 'C', 'D'];

    QUIZ.questions.forEach(function(q, qi) {
        html += '<div class="question-card' + (qi === 0 ? ' active' : '') + '" id="qCard' + qi + '">';
        html += '<div class="question-number-badge">Question ' + (qi + 1) + ' of ' + totalQ + '</div>';
        html += '<div class="question-text">' + q.question + '</div>';
        html += '<div class="options-list">';
        q.options.forEach(function(opt, oi) {
            html += '<div class="option-card" id="opt_' + qi + '_' + oi + '" onclick="selectOption(' + qi + ',' + oi + ')">';
            html += '<div class="option-letter">' + letters[oi] + '</div>';
            html += '<div class="option-text">' + opt + '</div>';
            html += '<div class="option-icon" id="optIcon_' + qi + '_' + oi + '"></div>';
            html += '</div>';
        });
        html += '</div>';

        // Solution box (hidden until review)
        html += '<div class="solution-box" id="solution_' + qi + '">';
        html += '<div class="solution-label">✅ Solution</div>';
        html += '<p>The correct answer is <strong>' + letters[q.correct] + '. ' + q.options[q.correct] + '</strong></p>';
        html += '</div>';

        // Nav buttons
        html += '<div class="question-nav">';
        html += '<button class="nav-btn-quiz prev" onclick="prevQuestion()" ' + (qi === 0 ? 'disabled' : '') + '>← Previous</button>';
        if (qi < totalQ - 1) {
            html += '<button class="nav-btn-quiz next" onclick="nextQuestion()">Next →</button>';
        } else {
            html += '<button class="nav-btn-quiz next" onclick="showConfirmModal()">Submit Quiz →</button>';
        }
        html += '</div>';
        html += '</div>';
    });
    main.innerHTML = html;
}

// ===== NAVIGATION =====
function showQuestion(idx) {
    if (idx < 0 || idx >= totalQ) return;
    currentQ = idx;
    // Hide all, show target
    document.querySelectorAll('.question-card').forEach(function(c) { c.classList.remove('active'); });
    document.getElementById('qCard' + idx).classList.add('active');
    // Update grid
    document.querySelectorAll('.q-num').forEach(function(n, i) {
        n.classList.remove('active');
        if (i === idx) n.classList.add('active');
    });
    // Scroll main area to top
    document.getElementById('quizMainArea').scrollTop = 0;
}

function nextQuestion() { if (currentQ < totalQ - 1) showQuestion(currentQ + 1); }
function prevQuestion() { if (currentQ > 0) showQuestion(currentQ - 1); }
function jumpToQuestion(idx) { showQuestion(idx); closeSidebar(); }

// ===== OPTION SELECTION =====
function selectOption(qIdx, optIdx) {
    if (quizSubmitted) return;
    userAnswers[qIdx] = optIdx;

    // Update visuals
    var opts = document.querySelectorAll('#qCard' + qIdx + ' .option-card');
    opts.forEach(function(o, i) {
        o.classList.remove('selected');
        if (i === optIdx) o.classList.add('selected');
    });

    // Mark answered in grid
    document.getElementById('qNum' + qIdx).classList.add('answered');

    // UX Feedback
    UI.showToast(`Question ${qIdx + 1} answered`, 'success', 1500);

    // Update stats
    updateStats();
}

// ===== STATS =====
function updateStats() {
    var answered = userAnswers.filter(function(a) { return a !== null; }).length;
    var remaining = totalQ - answered;
    var pct = Math.round((answered / totalQ) * 100);

    document.getElementById('statAnswered').textContent = answered;
    document.getElementById('statRemaining').textContent = remaining;
    document.getElementById('progressText').textContent = answered + ' / ' + totalQ;
    document.getElementById('progressFill').style.width = pct + '%';

    // Mobile
    if (document.getElementById('progressTextMobile')) {
        document.getElementById('progressTextMobile').textContent = answered + ' / ' + totalQ;
        document.getElementById('progressFillMobile').style.width = pct + '%';
    }
}

// ===== TIMER =====
function startTimer() {
    timerInterval = setInterval(function() {
        timeLeft--;
        if (timeLeft <= 0) {
            clearInterval(timerInterval);
            timeLeft = 0;
            autoSubmit();
        }
        updateTimerDisplay();
        // Warning at 60s
        if (timeLeft <= 60) {
            document.getElementById('timerBox').classList.add('warning');
        }
    }, 1000);
    updateTimerDisplay();
}

function updateTimerDisplay() {
    var m = Math.floor(timeLeft / 60);
    var s = timeLeft % 60;
    var str = (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
    document.getElementById('timerValue').textContent = str;
    if (document.getElementById('timerValueMobile')) {
        document.getElementById('timerValueMobile').textContent = str;
    }
}

function autoSubmit() {
    hideConfirmModal();
    submitQuiz();
}

// ===== CONFIRM MODAL =====
function showConfirmModal() {
    if (quizSubmitted) return;
    var answered = userAnswers.filter(function(a) { return a !== null; }).length;
    document.getElementById('modalAnswered').textContent = answered;
    document.getElementById('modalUnanswered').textContent = totalQ - answered;
    document.getElementById('confirmModal').classList.add('show');
}

function hideConfirmModal() {
    document.getElementById('confirmModal').classList.remove('show');
}

// ===== SUBMIT QUIZ =====
function submitQuiz() {
    if (quizSubmitted) return;
    quizSubmitted = true;
    clearInterval(timerInterval);
    hideConfirmModal();

    var elapsed = Math.round((Date.now() - startTime) / 1000);
    var correct = 0, incorrect = 0, skipped = 0;

    QUIZ.questions.forEach(function(q, i) {
        if (userAnswers[i] === null) {
            skipped++;
        } else if (userAnswers[i] === q.correct) {
            correct++;
        } else {
            incorrect++;
        }
    });

    var pct = Math.round((correct / totalQ) * 100);

    // Show correct/wrong on all options
    QUIZ.questions.forEach(function(q, qi) {
        var opts = document.querySelectorAll('#qCard' + qi + ' .option-card');
        opts.forEach(function(o, oi) {
            o.classList.add('disabled');
            if (oi === q.correct) {
                o.classList.add('correct');
                document.getElementById('optIcon_' + qi + '_' + oi).textContent = '✓';
            }
            if (userAnswers[qi] === oi && oi !== q.correct) {
                o.classList.add('wrong');
                document.getElementById('optIcon_' + qi + '_' + oi).textContent = '✗';
            }
        });
    });

    // Disable submit button
    document.getElementById('btnSubmitHeader').disabled = true;
    document.getElementById('btnSubmitHeader').textContent = 'Submitted ✓';

    // Populate result screen
    var emoji = pct >= 80 ? '🏆' : pct >= 60 ? '👍' : pct >= 40 ? '📝' : '💪';
    var subtitle = pct >= 80 ? 'Excellent performance!' : pct >= 60 ? 'Good job!' : pct >= 40 ? 'Keep practicing!' : 'Don\'t give up!';
    document.getElementById('resultEmoji').textContent = emoji;
    document.getElementById('resultSubtitle').textContent = subtitle;
    document.getElementById('resultScoreText').textContent = correct + '/' + totalQ;
    document.getElementById('resultPercentage').textContent = pct + '%';
    document.getElementById('resultCorrect').textContent = correct;
    document.getElementById('resultIncorrect').textContent = incorrect;
    document.getElementById('resultSkipped').textContent = skipped;

    var m = Math.floor(elapsed / 60);
    var s = elapsed % 60;
    document.getElementById('resultTime').textContent = m + ':' + (s < 10 ? '0' + s : s);

    // Animate ring
    var ring = document.getElementById('ringFill');
    var circumference = 439.82;
    var offset = circumference - (circumference * pct / 100);
    ring.style.strokeDashoffset = offset;
    ring.classList.add(pct >= 80 ? 'excellent' : pct >= 60 ? 'good' : pct >= 40 ? 'average' : 'poor');

    // Hide quiz, show results
    document.getElementById('quizLayout').style.display = 'none';
    document.getElementById('resultScreen').classList.add('show');
    if (document.getElementById('sidebarToggle')) document.getElementById('sidebarToggle').style.display = 'none';
    if (document.querySelector('.mobile-progress')) document.querySelector('.mobile-progress').style.display = 'none';

    // Save to server
    const stopLoading = UI.btnLoading('btnSubmitHeader', 'Saving...');
    fetch('/api/quiz-result', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            subject: QUIZ.subject,
            score: correct,
            totalQuestions: totalQ
        })
    }).then(res => res.json())
      .then(data => {
          stopLoading();
          if (data.success) {
              UI.showToast('Quiz results saved successfully!', 'success');
          } else {
              UI.showToast('Failed to save results. Please check your connection.', 'error');
          }
      })
      .catch(function(err) { 
          stopLoading();
          console.log('Save error:', err);
          UI.showToast('Network error while saving results.', 'error');
      });
}

// ===== REVIEW ANSWERS =====
function reviewAnswers() {
    document.getElementById('resultScreen').classList.remove('show');
    document.getElementById('resultScreen').style.display = 'none';
    document.getElementById('quizLayout').style.display = 'grid';

    // Show all solutions
    for (var i = 0; i < totalQ; i++) {
        document.getElementById('solution_' + i).classList.add('show');
    }
    showQuestion(0);
}

// ===== SIDEBAR TOGGLE (Mobile) =====
function toggleSidebar() {
    document.getElementById('quizSidebar').classList.toggle('open');
}
function closeSidebar() {
    document.getElementById('quizSidebar').classList.remove('open');
}

// ===== START =====
document.addEventListener('DOMContentLoaded', init);
</script>

    <script src="/js/ui-utils.js"></script>
    <div id="global-spinner"><div class="spinner-inner"></div></div>
</body>
</html>
