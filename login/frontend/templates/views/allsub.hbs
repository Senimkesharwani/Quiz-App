<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Subjects — BrainByte</title>
    <link rel="stylesheet" href="/css/allsub.css">
    <link rel="stylesheet" href="/css/globals.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <script src="https://kit.fontawesome.com/d4b6d93ef0.js" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Raleway:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
          
</head>
<body>
    {{> appNavbar }}
    
    <main class="allsub-main">
        <!-- Hero Section -->
        <section class="allsub-hero">
            <div class="container hero-content">
                <h1 class="hero-title">All Categories - Computer Science MCQs</h1>
                <p class="hero-subtitle">Welcome to our all-encompassing library of Computer Science Multiple-Choice Questions (MCQs). From Data Structures and Algorithms to AI and Software Engineering, explore thousands of questions updated daily.</p>
            </div>
        </section>

        <!-- Subjects Grid -->
        <div class="main-container">
            <!-- Subjects grouped for flex/grid -->
            <div class="subjects-wrapper">
                <div class="subject-card hover Networking">
                    <a href="/cn" class="card-title">Networking</a>
                    <div class="card-image">
                        <img src="/images/cn.jpg" alt="Networking">
                    </div>
                    <div class="card-description">
                        <p>Explore the intricacies of digital communication, from basic theory to the OSI Model and TCP/IP.</p>
                    </div>
                </div>

                <div class="subject-card hover Software">
                    <a href="/software" class="card-title">Software Engineering</a>
                    <div class="card-image">
                        <img src="/images/se.jpg" alt="Software Engineering">
                    </div>
                    <div class="card-description">
                        <p>Master software development lifecycles, methodologies, and quality assurance principles.</p>
                    </div>
                </div>

                <div class="subject-info-card">
                    <p><i class="fa-solid fa-quote-left"></i> Tailored for CSE learners, our platform offers a diverse range of MCQs covering fundamental concepts to advanced topics. With an intuitive interface, navigating through subjects becomes seamless. <i class="fa-solid fa-quote-right"></i></p>
                </div>

                <div class="subject-card hover Ca">
                    <a href="/ca" class="card-title">Computer Architecture</a>
                    <div class="card-image">
                        <img src="/images/ca.webp" alt="Computer Architecture">
                    </div>
                    <div class="card-description">
                        <p>Unveil the science behind computer design, machine language, and microarchitecture.</p>
                    </div>
                </div>

                <div class="subject-card hover dbms">
                    <a href="/dbms" class="card-title">DBMS</a>
                    <div class="card-image">
                        <img src="/images/dbms.jpg" alt="DBMS">
                    </div>
                    <div class="card-description">
                        <p>Get a firm grasp on relational databases, SQL, normalization, and data persistence.</p>
                    </div>
                </div>

                <div class="subject-card hover os">
                    <a href="/osmcq" class="card-title">Operating System</a>
                    <div class="card-image">
                        <img src="/images/os.jpg" alt="Operating System">
                    </div>
                    <div class="card-description">
                        <p>Dive deep into process scheduling, memory management, and file systems.</p>
                    </div>
                </div>

                <div class="subject-card hover DSA">
                    <a href="/dsa" class="card-title">Data Structures & Algorithms</a>
                    <div class="card-image">
                        <img src="/images/dsa.jpg" alt="DSA">
                    </div>
                    <div class="card-description">
                        <p>Journey through fundamentals like Arrays, Linked Lists, Trees, and Sorting Algorithms.</p>
                    </div>
                </div>

                <div class="subject-media-card">
                    <img src="/images/centerimg.png" alt="CS Topics Image">
                </div>

                <div class="subject-card hover AI">
                    <a href="/AI" class="card-title">Artificial Intelligence</a>
                    <div class="card-image">
                        <img src="/images/AI.jpg" alt="AI">
                    </div>
                    <div class="card-description">
                        <p>Cover topics from machine learning and neural networks to robotics and expert systems.</p>
                    </div>
                </div>

                <div class="subject-card hover Cpp">
                    <a href="/cpp" class="card-title">OOP Using C++</a>
                    <div class="card-image">
                        <img src="/images/C-Language.png" alt="C++">
                    </div>
                    <div class="card-description">
                        <p>Master encapsulation, inheritance, polymorphism, and abstraction in C++.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>


    
    
    <!-- footer section -->
    <footer class="allsub-footer">
        <div class="footer-container">
            <div class="footer-brand-section">
                <div class="footer-brand">
                    <div class="brand-icon">B</div>
                    <span class="brand-text">BrainByte</span>
                </div>
                <p class="footer-about">
                    BrainByte is a comprehensive directory of Objective Type Questions (MCQs) covering all Computer Science subjects. We provide a premium resource for competitive exams and technical interviews.
                </p>
            </div>
            
            <div class="footer-links-group">
                <div class="footer-col">
                    <h4 class="footer-title">Navigation</h4>
                    <ul class="footer-links">
                        <li><a href="/">Home</a></li>
                        <li><a href="/dashboard">Dashboard</a></li>
                        <li><a href="/allsub">All Subjects</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4 class="footer-title">Support</h4>
                    <ul class="footer-links">
                        <li><a href="#footer">About Us</a></li>
                        <li><a href="#footer">Contact Us</a></li>
                        <li><a href="#footer">Privacy Policy</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer-social-section">
                <h4 class="footer-title">Connect</h4>
                <div class="social-icons">
                    <a href="#" class="social-icon" aria-label="Facebook"><i class="fa-brands fa-facebook"></i></a>
                    <a href="#" class="social-icon" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#" class="social-icon" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                </div>
                <div class="footer-email">
                    <i class="fa-regular fa-envelope"></i>
                    <span>contact@brainbyte.com</span>
                </div>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>Copyright © 2024 BrainByte. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="/js/ui-utils.js"></script>
    <div id="global-spinner"><div class="spinner-inner"></div></div>
</body>
</html>